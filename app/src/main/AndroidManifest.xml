<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permission -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Yanda"
        android:usesCleartextTraffic="true">

        <!-- Splash Screen (Launcher) -->
        <activity
            android:name=".SplashScreenActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Main -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Base Navigation -->
        <activity
            android:name=".BaseActivity"
            android:exported="false" />

        <!-- WebView -->
        <activity
            android:name=".WebViewActivity"
            android:exported="false" />

        <!-- ListView -->
        <activity
            android:name=".Home.ListActivity"
            android:exported="false" />

        <!-- Register Flow -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".GmailInputActivity"
            android:exported="false" />

        <activity
            android:name=".RegisterSuccessActivity"
            android:exported="false" />

        <!-- Pertemuan 2 -->
        <activity
            android:name=".Home.pertemuan2.BangunRuangActivity"
            android:exported="false" />

        <!-- Pertemuan 3 -->
        <activity
            android:name=".Home.pertemuan3.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan3.WelcomeActivity"
            android:exported="false" />

        <!-- Pertemuan 4 -->
        <activity
            android:name=".Home.pertemuan4.Custom2Activity"
            android:exported="false" />

        <!-- Pertemuan 10 -->
        <activity
            android:name=".Home.pertemuan10.TenthActivity"
            android:exported="false" />

    </application>

</manifest>